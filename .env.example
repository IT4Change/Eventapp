# CalDAV (Baikal) — nur server-seitig genutzt, niemals im Browser.
# Default zeigt auf die lokale Compose-Instanz + den provisionierten admin-Account.
DAV_URL=http://localhost:8088
DAV_USERNAME=admin
DAV_PASSWORD=admin

# Web-Admin-Passwort von Baikal (wird von infra/baikal/init-bootstrap.sh genutzt)
BAIKAL_ADMIN_PASSWORD=admin

# Vorwärtsfenster für /api/events in Monaten
DAV_WINDOW_MONTHS=12
